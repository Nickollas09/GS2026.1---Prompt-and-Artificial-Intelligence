        "import random\n",
        "import ollama\n",
        "\n",
        "def gerar_dados_missao():\n",
        "    \"\"\"Gera dados simulados de telemetria conforme solicitado pelo edital.\"\"\"\n",
        "    temperatura = random.randint(10, 115)\n",
        "    energia = random.randint(5, 100)\n",
        "    comunicacao = random.choice([\"Estável\", \"Instável\", \"Crítica\"])\n",
        "    status_modulos = random.choice([\"Operacional\", \"Manutenção Requerida\", \"Falha de Hardware\"])\n",
        "    return temperatura, energia, comunicacao, status_modulos\n",
        "\n",
        "def verificar_alertas_sistema(temperatura, energia, comunicacao, status_modulos):\n",
        "    \"\"\"Estrutura lógica de tomada de decisão para regras de segurança automatizadas.\"\"\"\n",
        "    alertas = []\n",
        "    acoes = []\n",
        "\n",
        "    if temperatura > 90:\n",
        "        alertas.append(\" CRÍTICO: Superaquecimento detectado nos módulos térmicos!\")\n",
        "        acoes.append(\" SISTEMA: Ativando resfriamento líquido de emergência nas placas centrais.\")\n",
        "    elif temperatura < 15:\n",
        "        alertas.append(\" ALERTA: Temperatura abaixo da curva ideal de operação.\")\n",
        "        acoes.append(\" SISTEMA: Ligando aquecedores internos do chassi secundário.\")\n",
        "\n",
        "    if energia < 20:\n",
        "        alertas.append(\" CRÍTICO: Banco de baterias abaixo de 20% de carga residual!\")\n",
        "        acoes.append(\" SISTEMA: Desligando subsistemas não essenciais e ativando Modo de Economia.\")\n",
        "\n",
        "    if comunicacao == \"Crítica\":\n",
        "        alertas.append(\" CRÍTICO: Atenuação severa de sinal com a estação terrestre.\")\n",
        "        acoes.append(\" SISTEMA: Redirecionando matriz de antenas para redundância orbital.\")\n",
        "\n",
        "    if status_modulos == \"Falha de Hardware\":\n",
        "        alertas.append(\" CRÍTICO: Falha física estrutural detectada em módulo ativo.\")\n",
        "        acoes.append(\" SISTEMA: Isolando barramento lógico da unidade afetada e chaveando para backup.\")\n",
        "\n",
        "    return alertas, acoes\n",
        "\n",
        "def obter_analise_ia(temperatura, energia, comunicacao, status_modulos):\n",
        "    \"\"\"Envia os parâmetros unificados para o Llama 3.2 gerar a predição contextualizada.\"\"\"\n",
        "    system_prompt = (\n",
        "        \"Você é o software de IA do controle de missão espacial Mission Control AI. \"\n",
        "        \"Sua função é analisar a telemetria recebida, prever cenários de risco iminentes e fornecer \"\n",
        "        \"um diagnóstico operacional preciso, curto e de tom puramente técnico/científico.\"\n",
        "    )\n",
        "\n",
        "    user_prompt = (\n",
        "        f\"Métricas Atuais de Telemetria:\\n\"\n",
        "        f\"- Temperatura dos Módulos: {temperatura}°C\\n\"\n",
        "        f\"- Nível das Baterias: {energia}%\\n\"\n",
        "        f\"- Status do Sinal de Rádio: {comunicacao}\\n\"\n",
        "        f\"- Integridade Operacional: {status_modulos}\\n\"\n",
        "        f\"Gere o relatório preditivo imediato.\"\n",
        "    )\n",
        "\n",
        "    try:\n",
        "        resposta = ollama.chat(\n",
        "            model=\"llama3.2:1b\",\n",
        "            messages=[\n",
        "                {\"role\": \"system\", \"content\": system_prompt},\n",
        "                {\"role\": \"user\", \"content\": user_prompt}\n",
        "            ]\n",
        "        )\n",
        "        return resposta[\"message\"][\"content\"]\n",
        "    except Exception as e:\n",
        "        return f\"Erro de comunicação com o núcleo da IA: {e}\"\n",
        "\n",
        "def exibir_dashboard(temperatura, energia, comunicacao, status_modulos, alertas, acoes, analise_ia):\n",
        "    \"\"\"Gera uma saída limpa, organizada e altamente visual no console do terminal.\"\"\"\n",
        "    print(\"=\" * 70)\n",
        "    print(\"               MISSION CONTROL AI - MONITORAMENTO OPERACIONAL  \")\n",
        "    print(\"=\" * 70)\n",
        "    print(f\" Temperatura Geral  : {temperatura}°C\")\n",
        "    print(f\" Nível de Energia    : {energia}%\")\n",
        "    print(f\" Sinal de Comunicação: {comunicacao}\")\n",
        "    print(f\" Status dos Módulos  : {status_modulos}\")\n",
        "    print(\"-\" * 70)\n",
        "\n",
        "    print(\" STATUS DE ALERTAS AUTOMÁTICOS DO SISTEMA:\")\n",
        "    if alertas:\n",
        "        for al, ac in zip(alertas, acoes):\n",
        "            print(f\"{al}\\n -> {ac}\")\n",
        "    else:\n",
        "        print(\" Todos os sistemas operando dentro dos parâmetros de segurança nominais.\")\n",
        "    print(\"-\" * 70)\n",
        "\n",
        "    print(\" DIAGNÓSTICO E PREDIÇÃO DA INTELIGÊNCIA ARTIVICIAL:\")\n",
        "    print(analise_ia)\n",
        "    print(\"=\" * 70)\n",
        "\n",
        "print(\"Rodando varredura inicial do sistema...\")\n",
        "t, e, c, s = gerar_dados_missao()\n",
        "alertas_s, acoes_s = verificar_alertas_sistema(t, e, c, s)\n",
        "diagnostico_ia = obter_analise_ia(t, e, c, s)\n",
        "exibir_dashboard(t, e, c, s, alertas_s, acoes_s, diagnostico_ia)"
      ],
